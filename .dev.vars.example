DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx
API_KEY=local-dev-api-key-change-me
INBOX_DOMAIN=your-id.resend.app

# Optional: MCP browser login (Auth0) — see docs/MCP-OAUTH-IDP.md
# OIDC_ISSUER=https://YOUR-TENANT.us.auth0.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=

# Optional: Stripe Pro — see docs/STRIPE-SETUP.md · npm run wizard:stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# Optional: Workspace Agent (DeepSeek primary, Qwen fallback)
# WORKSPACE_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# QWEN_API_KEY=
# OpenRouter: WORKSPACE_LLM_PROVIDER=custom + OPENROUTER_API_KEY=sk-or-v1-...
# Local Ollama stack: npm run dev:docker:ollama — see docs/WORKSPACE-LOCAL-LLM.md
# Or host Ollama: WORKSPACE_LLM_PROVIDER=local + OLLAMA_MODEL=llama3.2
