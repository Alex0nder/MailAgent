{
  "name": "@mailagent/qa",
  "version": "0.1.15",
  "description": "Playwright/Cypress helpers for MailAgent test inboxes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alex0nder/MailAgent.git",
    "directory": "packages/mailagent-qa"
  },
  "homepage": "https://webmailagent.com/docs/qa.html",
  "bugs": "https://github.com/Alex0nder/MailAgent/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cypress": {
      "types": "./dist/cypress.d.ts",
      "import": "./dist/cypress.js"
    },
    "./notify": {
      "types": "./dist/notify.d.ts",
      "import": "./dist/notify.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  },
  "keywords": ["mailagent", "playwright", "e2e", "email", "testing"],
  "license": "MIT"
}
