{
  "name": "mailagent",
  "version": "0.1.0",
  "description": "Temporary email inboxes for AI agents & QA/E2E — MCP, REST, OTP/magic links. Cloudflare Workers, Neon, Resend. MIT.",
  "homepage": "https://webmailagent.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alex0nder/MailAgent.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 127.0.0.1 --port 8787",
    "verify": "node scripts/verify.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "smoke:agent": "node scripts/smoke-agent.mjs",
    "smoke:qa": "node scripts/smoke-qa.mjs",
    "issue:key": "node scripts/issue-api-key.mjs",
    "issue:key:db": "node scripts/issue-api-key.mjs --register",
    "issue:pilot-key": "node scripts/issue-api-key.mjs --register --label-prefix=ci-",
    "team:plan": "node scripts/set-team-plan.mjs",
    "setup:check": "node scripts/setup-check.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:qa": "node scripts/doctor.mjs --qa",
    "doctor:operator": "node scripts/doctor-operator.mjs",
    "doctor:oidc": "node scripts/doctor-oidc.mjs",
    "doctor:billing": "node scripts/doctor-billing.mjs",
    "doctor:security": "node scripts/doctor-security.mjs",
    "wizard:auth0": "node scripts/wizard-auth0-oidc.mjs",
    "wizard:stripe": "node scripts/wizard-stripe.mjs",
    "wizard:qa-pilot": "node scripts/wizard-qa-pilot.mjs",
    "wizard:qa-pilot:onboard": "node scripts/wizard-qa-pilot-onboard.mjs",
    "print:pilot-invite": "node scripts/print-pilot-invite.mjs",
    "setup:stripe-prod": "node scripts/setup-stripe-prod.mjs",
    "setup:oidc-prod": "node scripts/setup-oidc-prod.mjs",
    "rotate:oidc": "node scripts/setup-oidc-prod.mjs",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "types": "wrangler types",
    "db:migrate": "node scripts/migrate.mjs",
    "build:mcp": "cd mcp && npm install && npm run build",
    "build:qa": "cd packages/mailagent-qa && npm install && npm run build",
    "build:agent": "cd packages/mailagent-agent && npm install && npm run build",
    "publish:mcp": "npm run build:mcp && cd mcp && npm publish --access public",
    "publish:qa": "npm run build:qa && cd packages/mailagent-qa && npm publish --access public",
    "publish:agent": "npm run build:agent && cd packages/mailagent-agent && npm publish --access public",
    "publish:agent-py": "node scripts/publish-if-new-pypi.mjs",
    "publish:check": "node scripts/publish-check.mjs",
    "publish:all": "npm run publish:check && npm run publish:mcp && npm run publish:qa && npm run publish:agent",
    "test:allowlist": "npx tsx scripts/test-allowlist.ts",
    "test:extract": "npx tsx scripts/test-extract.ts",
    "test:preset-advisor": "npx tsx scripts/test-preset-advisor.ts",
    "test:contract:qa": "node scripts/contract-qa.mjs",
    "test:contract:qa:callback": "node scripts/contract-qa-callback.mjs",
    "test:contract:qa:notify": "node scripts/contract-qa-notify.mjs",
    "test:contract:qa:email-check": "node scripts/contract-qa-email-check.mjs",
    "test:contract:qa:attachments": "node scripts/contract-qa-attachments.mjs",
    "test:contract:qa:threads": "node scripts/contract-qa-threads.mjs",
    "test:contract:qa:domains": "node scripts/contract-qa-domains.mjs",
    "test:contract:qa:dedicated-resend": "node scripts/contract-qa-dedicated-resend.mjs",
    "test:contract:qa:search": "node scripts/contract-qa-search.mjs",
    "test:contract:qa:extract": "node scripts/contract-qa-extract.mjs",
    "test:contract:qa:console": "node scripts/contract-qa-console.mjs",
    "test:contract:qa:audit": "node scripts/contract-qa-audit.mjs",
    "test:contract:qa:console-inbox": "node scripts/contract-qa-console-inbox.mjs",
    "test:contract:qa:team-keys": "node scripts/contract-qa-team-keys.mjs",
    "test:contract:qa:agent": "node scripts/contract-qa-agent.mjs",
    "test:contract:qa:oidc": "MAILAGENT_API_URL=https://api.webmailagent.com node scripts/contract-qa-oidc.mjs",
    "test:contract:qa:billing": "MAILAGENT_API_URL=https://api.webmailagent.com node scripts/contract-qa-billing.mjs",
    "test:contract:qa:session": "node scripts/contract-qa-session.mjs",
    "test:contract:qa:outbound": "MAILAGENT_API_URL=https://api.webmailagent.com node scripts/contract-qa-outbound.mjs",
    "test:contract:all": "node scripts/test-contract-all.mjs",
    "test:prod": "node scripts/test-prod.mjs",
    "test:prod:gate": "node scripts/test-prod-gate.mjs",
    "test:pw:simulate": "playwright test -c examples/playwright/playwright.simulate.config.ts",
    "test:qa-pilot-starter": "node scripts/test-qa-pilot-starter.mjs",
    "test:qa-pilot-cypress-starter": "node scripts/test-qa-pilot-cypress-starter.mjs",
    "test:structured-extract": "npx tsx scripts/test-structured-extract.ts",
    "test:message-search": "npx tsx scripts/test-message-search.ts",
    "test:thread-resolve": "npx tsx scripts/test-thread-resolve.ts",
    "smoke:codex": "node scripts/smoke-codex.mjs",
    "verify:skills": "node scripts/verify-agent-skill.mjs",
    "sync:skills": "node scripts/sync-agent-skill.mjs",
    "sync:context-os": "node scripts/sync-context-os.mjs",
    "verify:codex": "node scripts/verify-codex-plugin.mjs",
    "prepare:catalog-pr": "node scripts/prepare-catalog-pr.mjs",
    "prepare:skills-pr": "node scripts/prepare-skills-pr.mjs",
    "import:skill-hub": "node scripts/import-skill-hub.mjs",
    "check:catalog-prs": "node scripts/check-catalog-prs.mjs",
    "harden:repo": "gh repo edit Alex0nder/MailAgent --enable-secret-scanning --enable-secret-scanning-push-protection",
    "package:codex": "node scripts/package-codex-plugin.mjs",
    "codex:install": "node scripts/codex-install.mjs",
    "test:pw:setup": "node scripts/playwright-global-setup.mjs",
    "ci:mailagent-alerts": "npm run build:qa && node scripts/ci-mailagent-alerts.mjs",
    "repo:github-about": "gh repo edit Alex0nder/MailAgent --description \"Temporary email inboxes for AI agents & QA/E2E — MCP, REST, OTP/magic links. Cloudflare Workers, Neon, Resend. MIT.\" --homepage https://webmailagent.com",
    "eval:context-os:route": "node context-os/eval/route-eval.mjs",
    "eval:context-os:router-build": "node context-os/eval/build-router-embeddings.mjs",
    "eval:context-os:route-semantic": "node context-os/eval/route-eval.mjs --semantic",
    "check:context-os-router": "node context-os/eval/route-eval.mjs",
    "eval:context-os:graph-build": "node context-os/eval/build-graph-index.mjs",
    "eval:context-os:dry": "node context-os/eval/run-eval.mjs --pilot --dry-run",
    "eval:context-os:dry-abc": "node context-os/eval/run-eval.mjs --pilot --dry-run --condition all",
    "eval:context-os:pilot": "node context-os/eval/run-eval.mjs --pilot --condition all",
    "eval:context-os": "node context-os/eval/run-eval.mjs --condition all",
    "eval:context-os:ab-gold": "node context-os/eval/run-eval.mjs --condition both --router gold",
    "eval:context-os:ab-keyword": "node context-os/eval/run-eval.mjs --condition both --router keyword",
    "eval:context-os:ab-semantic": "node context-os/eval/run-eval.mjs --condition both --router semantic",
    "eval:context-os:aggregate": "node context-os/eval/aggregate.mjs",
    "eval:context-os:tokens": "node context-os/eval/tokens-report.mjs",
    "eval:context-os:export": "node context-os/eval/export-results.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "hono": "^4.11.1",
    "jose": "^6.2.3",
    "nanoid": "^5.1.6",
    "parse-otp-message": "^1.0.2",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260120.0",
    "@playwright/test": "^1.51.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
