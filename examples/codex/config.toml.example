# MailAgent MCP for OpenAI Codex
# Copy to ~/.codex/config.toml or .codex/config.toml (trusted project)
# Docs: https://github.com/Alex0nder/MailAgent/blob/main/docs/CODEX.md

# --- Option A: stdio via published npm package (recommended) ---
[mcp_servers.mailagent]
command = "npx"
args = ["-y", "-p", "@mailagent/mcp@0.2.0", "mailagent-mcp"]

[mcp_servers.mailagent.env]
MAILAGENT_API_URL = "https://api.webmailagent.com"
MAILAGENT_API_KEY = "REPLACE_WITH_YOUR_KEY"

# --- Option B: local dev (MailAgent repo checkout) ---
# [mcp_servers.mailagent-local]
# command = "node"
# args = ["/absolute/path/to/MailAgent/mcp/dist/index.js"]
#
# [mcp_servers.mailagent-local.env]
# MAILAGENT_API_URL = "http://127.0.0.1:8787"
# MAILAGENT_API_KEY = "from .dev.vars"

# --- Option C: remote Streamable HTTP (no subprocess) ---
# [mcp_servers.mailagent-remote]
# url = "https://api.webmailagent.com/mcp"
#
# [mcp_servers.mailagent-remote.http_headers]
# Authorization = "Bearer REPLACE_WITH_YOUR_KEY"
# Accept = "application/json, text/event-stream"
