# Neon Postgres (https://neon.tech)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx

# Домен приёма: из Dashboard → Emails → Receiving (например abc123.resend.app)
INBOX_DOMAIN=your-id.resend.app

# Секрет для агентов (curl / MCP)
API_KEY=generate-a-long-random-string
# Опционально: несколько ключей для пилотов (через запятую, wrangler secret put API_KEYS)
# API_KEYS=key-one,key-two

DEFAULT_TTL_MINUTES=30

# Hosted only (wrangler KV RATE_LIMIT): requests per minute per API key
# RATE_LIMIT_PER_MINUTE=120

# Stripe Pro (optional): npm run issue:key:db then POST /v1/billing/checkout
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# Verified From for outbound send (Resend). See public/docs/outbound.html
# OUTBOUND_FROM=noreply@yourdomain.com

# MCP (Cursor) — URL задеплоенного Worker или http://127.0.0.1:8787 локально
# local: http://127.0.0.1:8787 | prod: https://api.webmailagent.com
MAILAGENT_API_URL=http://127.0.0.1:8787
MAILAGENT_API_KEY=same-as-API_KEY-above

# OIDC IdP для MCP browser login (optional, wrangler secret put)
# OIDC_ISSUER=https://YOUR-TENANT.us.auth0.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=
