# Neon Postgres (https://neon.tech)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx

# Inbound domain: Dashboard → Emails → Receiving (e.g. abc123.resend.app)
INBOX_DOMAIN=your-id.resend.app

# Secret for agents (curl / MCP)
API_KEY=generate-a-long-random-string
# Optional: multiple pilot keys (comma-separated, wrangler secret put API_KEYS)
# API_KEYS=key-one,key-two

DEFAULT_TTL_MINUTES=30

# Hosted only (wrangler KV RATE_LIMIT): requests per minute per API key
# RATE_LIMIT_PER_MINUTE=120

# Stripe Pro (optional): npm run issue:key:db then POST /v1/billing/checkout
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# Verified From for outbound send (Resend). See public/docs/outbound.html
# OUTBOUND_FROM=noreply@yourdomain.com

# Workspace Agent LLM (optional; autonomous replies require at least one)
# WORKSPACE_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus
# DeepSeek and Qwen automatically fall back to each other when both are configured.

# MCP (Cursor) — deployed Worker URL or http://127.0.0.1:8787 locally
# local: http://127.0.0.1:8787 | prod: https://api.webmailagent.com
MAILAGENT_API_URL=http://127.0.0.1:8787
MAILAGENT_API_KEY=same-as-API_KEY-above

# Optional: PyPI publish (npm run publish:agent-py) — also GitHub secret PYPI_API_TOKEN
# PYPI_API_TOKEN=pypi-…

# OIDC IdP for MCP browser login (optional, wrangler secret put)
# OIDC_ISSUER=https://YOUR-TENANT.us.auth0.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=
